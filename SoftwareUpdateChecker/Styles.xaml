<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ######################################################################### -->
    <!--                             THEME RESOURCES                               -->
    <!-- ######################################################################### -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="AppTitleBarBackgroundDark" Color="#1a1a1a" />
            <!-- {ThemeResource SystemListLowColor} -->
            <SolidColorBrush x:Key="AppTitleBarForegroundDark" Color="White" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="AppTitleBarBackgroundLight" Color="#e6e6e6" />
            <!-- {ThemeResource SystemListLowColor} -->
            <SolidColorBrush x:Key="AppTitleBarForegroundLight" Color="Black" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>