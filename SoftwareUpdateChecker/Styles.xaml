<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ######################################################################### -->
    <!--                             THEME RESOURCES                               -->
    <!-- ######################################################################### -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
            <!-- {ThemeResource SystemListLowColor} -->
            <SolidColorBrush x:Key="AppTitleBarBackgroundColor" Color="#191919" />
            <SolidColorBrush x:Key="TextColor" Color="White" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
            <!-- {ThemeResource SystemListLowColor} -->
            <SolidColorBrush x:Key="AppTitleBarBackgroundColor" Color="#e6e6e6" />
            <SolidColorBrush x:Key="TextColor" Color="Black" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>